{
  "name": "@tokovo/device-camera",
  "version": "0.1.0",
  "description": "Production-grade cinematic camera system for Tokovo",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tokovo-camera": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "test": "vitest run",
    "camera:lint": "node ./dist/cli.js lint",
    "camera:doctor": "node ./dist/cli.js doctor",
    "camera:preview": "node ./dist/cli.js preview",
    "camera:migrate-v1": "node ./dist/cli.js migrate-v1",
    "bench": "vitest --run src/__tests__/perf.budget.test.ts"
  },
  "dependencies": {
    "@tokovo/core": "workspace:*",
    "@tokovo/react": "workspace:*",
    "@tokovo/ir": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "peerDependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "tokovo",
    "camera",
    "cinematography",
    "video",
    "remotion"
  ],
  "license": "MIT"
}
