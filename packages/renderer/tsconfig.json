{
    "extends": "../../tsconfig.lib.json",
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "jsx": "react-jsx"
    },
    "references": [
        { "path": "../core" },
        { "path": "../compiler" },
        { "path": "../device-camera" },
