{
  "name": "@tokovo/voice",
  "version": "0.0.1",
  "description": "AI voice generation and rendering for Tokovo video production",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./scripts": "./src/scripts/index.ts"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "generate": "tsx bin/generate.ts",
    "sync": "tsx bin/sync.ts",
    "voice:generate": "tsx bin/generate.ts",
    "voice:sync": "tsx bin/sync.ts"
  },
  "dependencies": {
    "@tokovo/core": "workspace:*",
    "@tokovo/ir": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "18.2.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0",
    "remotion": "^4.0.0"
  }
}
