{
    "name": "@tokovo/background",
    "version": "0.1.0",
    "description": "Background layer system for Tokovo video rendering",
    "main": "./dist/index.js",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
        ".": {
            "types": "./dist/index.d.ts",
            "import": "./dist/index.mjs",
            "require": "./dist/index.js"
        }
    },
    "scripts": {
        "build": "tsup src/index.ts --format cjs,esm --dts",
        "dev": "tsup src/index.ts --format cjs,esm --dts --watch",
        "typecheck": "tsc --noEmit",
        "test": "pnpm exec vitest run --passWithNoTests",
        "clean": "rm -rf dist"
    },
    "dependencies": {
        "@tokovo/core": "workspace:*"
    },
    "peerDependencies": {
        "react": "^18.0.0",
        "remotion": "^4.0.0"
    },
    "devDependencies": {
        "@types/react": "^18.2.0",
        "react": "^18.2.0",
        "remotion": "^4.0.0",
        "tsup": "^8.0.0",
        "typescript": "^5.0.0"
    }
}
