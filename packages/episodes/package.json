{
  "name": "@tokovo/episodes",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tokovo-validate": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./stories": {
      "types": "./dist/stories/index.d.ts",
      "default": "./dist/stories/index.js"
    },
    "./showcases": {
      "types": "./dist/showcases/index.d.ts",
      "default": "./dist/showcases/index.js"
    },
    "./showcases/apps": {
      "types": "./dist/showcases/apps/index.d.ts",
      "default": "./dist/showcases/apps/index.js"
    },
    "./showcases/system": {
      "types": "./dist/showcases/system/index.d.ts",
      "default": "./dist/showcases/system/index.js"
    },
    "./v2": {
      "types": "./dist/v2/index.d.ts",
      "default": "./dist/v2/index.js"
    },
    "./tests": {
      "types": "./dist/tests/index.d.ts",
      "default": "./dist/tests/index.js"
    },
    "./code-first-episode": {
      "types": "./dist/code-first-episode.d.ts",
      "default": "./dist/code-first-episode.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/runtime src/registry src/types src/runtime-bootstrap.ts src/validate-workspace.ts src/stories src/tests --ext .ts,.tsx",
    "validate": "tsx src/cli.ts",
    "validate:workspace": "tsx src/validate-workspace.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tokovo/core": "workspace:*",
    "@tokovo/dsl": "workspace:*",
    "@tokovo/ir": "workspace:*",
    "@tokovo/compiler": "workspace:*",
    "@tokovo/voice": "workspace:*",
    "@tokovo/react": "workspace:*",
    "@tokovo/reactions": "workspace:*",
    "@tokovo/renderer": "workspace:*",
    "@tokovo/devices": "workspace:*",
    "@tokovo/overlay": "workspace:*",
    "@tokovo/apps-whatsapp": "workspace:*",
    "@tokovo/apps-imessage": "workspace:*",
    "@tokovo/apps-instagram": "workspace:*",
    "@tokovo/apps-x": "workspace:*",
    "@tokovo/apps-linkedin": "workspace:*",
    "@tokovo/apps-snapchat": "workspace:*",
    "@tokovo/apps-teams": "workspace:*",
    "@tokovo/apps-typewriter": "workspace:*",
    "@tokovo/device-camera": "workspace:*",
    "@tokovo/device-keyboard": "workspace:*",
    "@tokovo/device-notifications": "workspace:*",
    "zod": "^4.2.1",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "vitest": "^1.0.0"
  }
}
