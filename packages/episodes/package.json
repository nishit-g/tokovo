{
  "name": "@tokovo/episodes",
  "version": "0.0.0",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "tokovo-validate": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./production": {
      "types": "./dist/production/index.d.ts",
      "default": "./dist/production/index.js"
    },
    "./showcases": {
      "types": "./dist/showcases/index.d.ts",
      "default": "./dist/showcases/index.js"
    },
    "./v2": {
      "types": "./dist/v2/index.d.ts",
      "default": "./dist/v2/index.js"
    },
    "./tests": {
      "types": "./dist/tests/index.d.ts",
      "default": "./dist/tests/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "lint": "eslint . --ext .ts,.tsx",
    "validate": "tsx src/cli.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@tokovo/creator": "workspace:*",
    "@tokovo/dsl": "workspace:*",
    "@tokovo/ir": "workspace:*",
    "@tokovo/compiler": "workspace:*",
    "@tokovo/voice": "workspace:*",
    "@tokovo/apps-whatsapp": "workspace:*",
    "@tokovo/apps-imessage": "workspace:*",
    "@tokovo/apps-x": "workspace:*",
    "@tokovo/apps-linkedin": "workspace:*",
    "@tokovo/apps-snapchat": "workspace:*",
    "@tokovo/apps-teams": "workspace:*",
    "@tokovo/apps-typewriter": "workspace:*",
    "@tokovo/device-camera": "workspace:*",
    "@tokovo/device-keyboard": "workspace:*",
    "@tokovo/device-notifications": "workspace:*",
    "zod": "^3.0.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "@types/node": "^20.0.0",
    "tsx": "^4.0.0",
    "vitest": "^1.0.0"
  }
}
