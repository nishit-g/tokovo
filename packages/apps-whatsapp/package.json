{
  "name": "@tokovo/apps-whatsapp",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./plugin": {
      "types": "./dist/plugin/index.d.ts",
      "default": "./dist/plugin/index.js"
    },
    "./contract": {
      "types": "./dist/contract/index.d.ts",
      "default": "./dist/contract/index.js"
    },
    "./dsl": {
      "types": "./dist/dsl/index.d.ts",
      "default": "./dist/dsl/index.js"
    },
    "./lowering": {
      "types": "./dist/lowering/index.d.ts",
      "default": "./dist/lowering/index.js"
    },
    "./runtime": {
      "types": "./dist/runtime/index.d.ts",
      "default": "./dist/runtime/index.js"
    },
    "./ui": {
      "types": "./dist/ui/index.d.ts",
      "default": "./dist/ui/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@remotion/media": "4.0.409",
    "@tokovo/core": "workspace:*",
    "@tokovo/device-camera": "workspace:*",
    "@tokovo/ir": "workspace:*",
    "@tokovo/react": "workspace:*",
    "lucide-react": "^0.263.1",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.409",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "18.3.1",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0",
    "immer": "^10.0.0"
  }
}
