{
  "name": "tokovo-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "turbo run build",
    "build:video": "turbo run build --filter=video-runner...",
    "dev": "turbo run dev --concurrency 15",
    "dev:video": "pnpm build:video && pnpm --filter video-runner dev",
    "watch:video": "turbo watch build --filter=video-runner...",
    "lint": "turbo run lint",
    "camera:lint": "pnpm --filter @tokovo/device-camera build && pnpm --filter @tokovo/device-camera camera:lint",
    "camera:doctor": "pnpm --filter @tokovo/device-camera build && pnpm --filter @tokovo/device-camera camera:doctor",
    "camera:bench": "pnpm --filter @tokovo/device-camera build && pnpm --filter @tokovo/device-camera bench",
    "camera:ci": "pnpm camera:lint && pnpm camera:bench",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "typecheck": "turbo run typecheck",
    "create-plugin": "pnpm turbo gen plugin",
    "create-episode": "pnpm turbo gen episode",
    "test": "pnpm -r test",
    "ci": "pnpm lint && pnpm typecheck && pnpm test && pnpm build",
    "validate": "pnpm --filter @tokovo/episodes validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@next/eslint-plugin-next": "^15.1.0",
    "@turbo/gen": "^2.8.3",
    "@types/node": "^22.0.0",
    "eslint": "^9.0.0",
    "prettier": "^3.5.0",
    "ts-node": "^10.9.0",
    "turbo": "^2.8.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@10.28.2",
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "overrides": {
      "react": "18.3.1",
      "react-dom": "18.3.1"
    }
  }
}
