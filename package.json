{
  "name": "tokovo-monorepo",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:check": "eslint . --max-warnings 0",
    "format": "prettier --write \"**/*.{ts,tsx,md}\"",
    "create-plugin": "npx ts-node templates/scripts/create-plugin.ts",
    "create-episode": "npx ts-node templates/scripts/create-episode.ts",
    "validate": "pnpm --filter @tokovo/episodes validate"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^20.0.0",
    "eslint": "^9.0.0",
    "prettier": "latest",
    "ts-node": "^10.9.0",
    "turbo": "latest",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.0.0"
  },
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  }
}
