import type { WorldState } from "@tokovo/core";
import type { {{ pascalCase name }}State, Note } from "./state";

// Selectors for accessing plugin state

export function get{{ pascalCase name }}State(world: WorldState): {{ pascalCase name }}State | undefined {
  return world.appState?.["app_{{ name }}"] as {{ pascalCase name }}State | undefined;
}

export function getNotes(world: WorldState): Note[] {
  return get{{ pascalCase name }}State(world)?.notes ?? [];
}

export function getActiveNote(world: WorldState): Note | null {
  const state = get{{ pascalCase name }}State(world);
  if (!state?.activeNoteId) return null;
  return state.notes.find((n) => n.id === state.activeNoteId) ?? null;
}

export function getCurrentScreen(world: WorldState): "list" | "detail" | "editor" {
  return get{{ pascalCase name }}State(world)?.currentScreen ?? "list";
}
