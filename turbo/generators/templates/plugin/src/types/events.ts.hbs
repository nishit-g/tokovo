import type { TrackEventBase } from "@tokovo/ir";

export type {{ pascalCase name }}EventType =
  | "NOTE_CREATE"
  | "NOTE_VIEW"
  | "NOTE_EDIT"
  | "NOTE_DELETE";

export type {{ pascalCase name }}EventKind =
  | "ADD_NOTE"
  | "UPDATE_NOTE"
  | "DELETE_NOTE"
  | "SET_ACTIVE_NOTE"
  | "SET_SCREEN";

export interface NoteCreatePayload {
  id: string;
  title: string;
  content: string;
  createdAt?: number;
  updatedAt?: number;
}

export interface NoteViewPayload {
  noteId: string;
}

export interface NoteEditPayload {
  noteId: string;
  title?: string;
  content?: string;
  updatedAt?: number;
}

export interface NoteDeletePayload {
  noteId: string;
}

export type {{ pascalCase name }}TrackEvent = TrackEventBase & {
  kind: "APP";
  appId: "app_{{ name }}";
} & (
    | { type: "NOTE_CREATE"; payload: NoteCreatePayload }
    | { type: "NOTE_VIEW"; payload: NoteViewPayload }
    | { type: "NOTE_EDIT"; payload: NoteEditPayload }
    | { type: "NOTE_DELETE"; payload: NoteDeletePayload }
  );
