import { describe, it, expect } from "vitest";
import {
  get{{ pascalCase name }}State,
  getNotes,
  getActiveNote,
  getCurrentScreen,
} from "../runtime/selectors";
import { create{{ pascalCase name }}InitialState } from "../runtime/state";
import type { WorldState } from "@tokovo/core";
import { DEFAULT_AUDIO_STATE, DEFAULT_BASE_CAMERA_STATE } from "@tokovo/core";

describe("{{ pascalCase name }} Selectors", () => {
  it("get{{ pascalCase name }}State returns plugin state", () => {
    const world: WorldState = {
      appState: {
        "app_{{ name }}": create{{ pascalCase name }}InitialState(),
      },
      devices: {},
      camera: DEFAULT_BASE_CAMERA_STATE,
      audio: DEFAULT_AUDIO_STATE,
    } as WorldState;

    const state = get{{ pascalCase name }}State(world);
    expect(state).toBeDefined();
    expect(state?.notes).toEqual([]);
  });

  it("getNotes returns notes array", () => {
    const world: WorldState = {
      appState: {
        "app_{{ name }}": {
          ...create{{ pascalCase name }}InitialState(),
          notes: [
            {
              id: "1",
              title: "Test",
              content: "Content",
              createdAt: 10,
              updatedAt: 20,
            },
          ],
        },
      },
      devices: {},
      camera: DEFAULT_BASE_CAMERA_STATE,
      audio: DEFAULT_AUDIO_STATE,
    } as WorldState;

    const notes = getNotes(world);
    expect(notes).toHaveLength(1);
    expect(notes[0].title).toBe("Test");
  });

  it("getActiveNote returns active note", () => {
    const now = 42;
    const world: WorldState = {
      appState: {
        "app_{{ name }}": {
          notes: [
            { id: "1", title: "Test", content: "Content", createdAt: now, updatedAt: now },
          ],
          activeNoteId: "1",
          currentScreen: "detail" as const,
        },
      },
      devices: {},
      camera: DEFAULT_BASE_CAMERA_STATE,
      audio: DEFAULT_AUDIO_STATE,
    } as WorldState;

    const note = getActiveNote(world);
    expect(note).toBeDefined();
    expect(note?.title).toBe("Test");
  });

  it("getCurrentScreen returns current screen", () => {
    const world: WorldState = {
      appState: {
        "app_{{ name }}": {
          ...create{{ pascalCase name }}InitialState(),
          currentScreen: "editor" as const,
        },
      },
      devices: {},
      camera: DEFAULT_BASE_CAMERA_STATE,
      audio: DEFAULT_AUDIO_STATE,
    } as WorldState;

    const screen = getCurrentScreen(world);
    expect(screen).toBe("editor");
  });
});
