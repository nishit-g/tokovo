import { parseTimeToFrames } from "@tokovo/dsl";
import type { {{ pascalCase name }}TrackEvent } from "../types";

type GetDeclarationOrder = () => number;

export interface CreateNoteInput {
  id?: string;
  title: string;
  content: string;
  createdAt?: number;
  updatedAt?: number;
}

export interface EditNoteInput {
  title?: string;
  content?: string;
  updatedAt?: number;
}

type PayloadInput =
  | Record<string, unknown>
  | ((order: number) => Record<string, unknown>);

// Utility for deterministic note IDs (frame + declaration order)
function createNoteId(frame: number, order: number): string {
  return `note-${frame}-${order}`;
}

class {{ pascalCase name }}PointBuilder {
  constructor(
    private _frame: number,
    private _deviceId: string,
    private _events: {{ pascalCase name }}TrackEvent[],
    private _getOrder: GetDeclarationOrder,
  ) {}

  private _push(type: string, payload: PayloadInput, duration?: number): void {
    const order = this._getOrder();
    const resolvedPayload = typeof payload === "function" ? payload(order) : payload;
    this._events.push({
      at: this._frame,
      duration,
      kind: "APP",
      appId: "app_{{ name }}",
      type,
      payload: resolvedPayload,
      deviceId: this._deviceId,
      _declarationOrder: order,
    } as {{ pascalCase name }}TrackEvent);
  }

  createNote(data: CreateNoteInput): void {
    this._push("NOTE_CREATE", (order) => ({
      id: data.id ?? createNoteId(this._frame, order),
      title: data.title,
      content: data.content,
      createdAt: data.createdAt,
      updatedAt: data.updatedAt ?? data.createdAt,
    }));
  }

  viewNote(noteId: string): void {
    this._push("NOTE_VIEW", { noteId });
  }

  editNote(noteId: string, data: EditNoteInput): void {
    this._push("NOTE_EDIT", { noteId, ...data });
  }

  deleteNote(noteId: string): void {
    this._push("NOTE_DELETE", { noteId });
  }
}

class {{ pascalCase name }}SpanBuilder {
  constructor(
    private _frame: number,
    private _duration: number,
    private _deviceId: string,
    private _events: {{ pascalCase name }}TrackEvent[],
    private _getOrder: GetDeclarationOrder,
  ) {}

  private _push(type: string, payload: PayloadInput): void {
    const order = this._getOrder();
    const resolvedPayload = typeof payload === "function" ? payload(order) : payload;
    this._events.push({
      at: this._frame,
      duration: this._duration,
      kind: "APP",
      appId: "app_{{ name }}",
      type,
      payload: resolvedPayload,
      deviceId: this._deviceId,
      _declarationOrder: order,
    } as {{ pascalCase name }}TrackEvent);
  }

  createNote(data: CreateNoteInput): void {
    this._push("NOTE_CREATE", (order) => ({
      id: data.id ?? createNoteId(this._frame, order),
      title: data.title,
