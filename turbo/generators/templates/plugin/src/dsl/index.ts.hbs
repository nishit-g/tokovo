      createdAt: data.createdAt,
      updatedAt: data.updatedAt ?? data.createdAt,
    }));
  }

  viewNote(noteId: string): void {
    this._push("NOTE_VIEW", { noteId });
  }

  editNote(noteId: string, data: EditNoteInput): void {
    this._push("NOTE_EDIT", { noteId, ...data });
  }

  deleteNote(noteId: string): void {
    this._push("NOTE_DELETE", { noteId });
  }
}

export class {{ pascalCase name }}TrackBuilder {
  _events: {{ pascalCase name }}TrackEvent[] = [];

  constructor(
    private _fps: number,
    private _deviceId: string,
    private _getOrder: GetDeclarationOrder,
  ) {}

  at(time: string | number): {{ pascalCase name }}PointBuilder {
    const frame = typeof time === "number" ? time : parseTimeToFrames(time, this._fps);
    return new {{ pascalCase name }}PointBuilder(
      frame,
      this._deviceId,
      this._events,
      this._getOrder,
    );
  }

  span(start: string | number, end: string | number): {{ pascalCase name }}SpanBuilder {
    const startFrame = typeof start === "number" ? start : parseTimeToFrames(start, this._fps);
    const endFrame = typeof end === "number" ? end : parseTimeToFrames(end, this._fps);
    const duration = Math.max(0, endFrame - startFrame);
    return new {{ pascalCase name }}SpanBuilder(
      startFrame,
      duration,
      this._deviceId,
      this._events,
      this._getOrder,
    );
  }
}
