// Transforms TrackEvents → RuntimeEvents
import type { TrackEvent } from "@tokovo/ir";
import type { RuntimeEvent } from "@tokovo/core";
import type { {{ pascalCase name }}TrackEvent } from "../types";

export interface {{ pascalCase name }}LoweringHandler {
  lower: (event: TrackEvent) => RuntimeEvent[];
}

function is{{ pascalCase name }}TrackEvent(
  event: TrackEvent,
): event is {{ pascalCase name }}TrackEvent {
  return (
    (event as { kind?: string }).kind === "APP" &&
    (event as { appId?: string }).appId === "app_{{ name }}"
  );
}

function getTimestamp(event: TrackEvent, override?: number): number {
  return typeof override === "number" ? override : event.at;
}

// Helper to build RuntimeEvent with all required fields
function createRuntimeEvent(
  event: TrackEvent,
  type: string,
  payload: unknown
): RuntimeEvent {
  return {
    at: event.at,
    kind: "APP",
    appId: "app_{{ name }}",
    type: type,
    payload: payload,
    deviceId: event.deviceId,
  };
}

export const {{ camelCase name }}Lowering: {{ pascalCase name }}LoweringHandler = {
  lower: (event: TrackEvent): RuntimeEvent[] => {
    if (!is{{ pascalCase name }}TrackEvent(event)) {
      return [];
    }
    const payload = (event.payload ?? {}) as Record<string, unknown>;
    switch (event.type) {
      case "NOTE_CREATE": {
        const createdAt = getTimestamp(event, payload.createdAt as number | undefined);
        const updatedAt =
          typeof payload.updatedAt === "number" ? payload.updatedAt : createdAt;
        return [
          createRuntimeEvent(event, "ADD_NOTE", {
            id: payload.id ?? `note-${event.at}-${event._declarationOrder ?? 0}`,
            title: payload.title,
            content: payload.content,
            createdAt,
            updatedAt,
          }),
        ];
      }
      case "NOTE_VIEW":
        return [
          createRuntimeEvent(event, "SET_ACTIVE_NOTE", { noteId: payload.noteId }),
          createRuntimeEvent(event, "SET_SCREEN", { screen: "detail" }),
        ];
      case "NOTE_EDIT":
        return [
          createRuntimeEvent(event, "UPDATE_NOTE", {
            noteId: payload.noteId,
            title: payload.title,
            content: payload.content,
            updatedAt: getTimestamp(event, payload.updatedAt as number | undefined),
          }),
        ];
      case "NOTE_DELETE":
        return [
          createRuntimeEvent(event, "DELETE_NOTE", { noteId: payload.noteId }),
        ];
      default:
        return [];
    }
  },
};
