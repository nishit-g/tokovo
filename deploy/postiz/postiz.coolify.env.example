MAIN_URL=https://postiz.tokovo.io
FRONTEND_URL=https://postiz.tokovo.io
NEXT_PUBLIC_BACKEND_URL=https://postiz.tokovo.io/api
BACKEND_INTERNAL_URL=http://localhost:3000
JWT_SECRET=replace-with-a-long-random-secret
IS_GENERAL=true
RUN_CRON=true
DISABLE_REGISTRATION=false

# Use R2 in production so provider callbacks and scheduled media pulls stay HTTPS-reachable.
STORAGE_PROVIDER=cloudflare
CLOUDFLARE_ACCOUNT_ID=replace-with-r2-account-id
CLOUDFLARE_ACCESS_KEY=replace-with-r2-access-key
CLOUDFLARE_SECRET_ACCESS_KEY=replace-with-r2-secret
CLOUDFLARE_BUCKETNAME=replace-with-r2-bucket
CLOUDFLARE_REGION=auto
CLOUDFLARE_BUCKET_URL=https://assets.tokovo.io
UPLOAD_DIRECTORY=/uploads
NEXT_PUBLIC_UPLOAD_DIRECTORY=/uploads

POSTIZ_DB_USER=postiz
POSTIZ_DB_PASSWORD=replace-with-a-strong-password
POSTIZ_DB_NAME=postiz
POSTIZ_REDIS_PASSWORD=replace-with-a-strong-redis-password

TEMPORAL_DB_USER=temporal
TEMPORAL_DB_PASSWORD=replace-with-a-strong-temporal-password
TEMPORAL_DB_NAME=temporal

OPENAI_API_KEY=

X_API_KEY=
X_API_SECRET=
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
YOUTUBE_CLIENT_ID=
YOUTUBE_CLIENT_SECRET=
THREADS_APP_ID=
THREADS_APP_SECRET=
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=
TIKTOK_CLIENT_ID=
TIKTOK_CLIENT_SECRET=

# Notes:
# - Postiz auth "Continue with Google" uses YOUTUBE_CLIENT_ID / YOUTUBE_CLIENT_SECRET.
# - Use DISABLE_REGISTRATION=false only for initial admin bootstrap, then set it to true.
# - Keep Railway live until DB restore, OAuth checks, and scheduled publishing all pass.
