R2_BUCKET=tokovo
R2_ENDPOINT=https://<cloudflare-account-id>.r2.cloudflarestorage.com
R2_REGION=auto
R2_ACCESS_KEY_ID=replace-with-r2-access-key
R2_SECRET_ACCESS_KEY=replace-with-r2-secret-key
# Optional: set to a system Chromium/Chrome path for local rendering if auto-detection fails.
# TOKOVO_BROWSER_EXECUTABLE=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome
# Optional: if source assets are hosted on a CDN/R2 custom domain, point the Remotion bundle here.
# Example: https://assets.tokovo.dev
# TOKOVO_PUBLIC_ASSET_BASE_URL=
# Optional: public base URL for uploaded render artifacts. Use a public bucket hostname or custom domain.
# Example: https://renders.tokovo.dev
# R2_PUBLIC_BASE_URL=
# Optional: prefix for all uploaded render artifact object keys.
# Example: prod
# R2_KEY_PREFIX=
# Optional: render service tuning knobs.
# TOKOVO_RENDER_SERVICE_POLL_MS=2000
# TOKOVO_RENDER_MAX_CONCURRENCY=4
# Optional: pretty console log tuning for local debugging and operators.
# TOKOVO_LOG_PROFILE=full
# Recommended "show me everything" preset for bootstrap, lifecycle, and event flow:
# TOKOVO_LOG_LEVEL=debug
# TOKOVO_LOG_COMPONENTS=*
# TOKOVO_LOG_CONSOLE=true
# TOKOVO_LOG_COLORS=true
# TOKOVO_LOG_TIMESTAMPS=true
# TOKOVO_LOG_INCLUDE_STACKS=true
# TOKOVO_LOG_EVENTS=true
# TOKOVO_LOG_PERF=true
# TOKOVO_LOG_AUDIO=true
# TOKOVO_LOG_TIMING_THRESHOLD_MS=1
#
# Lower-noise operator preset:
# TOKOVO_LOG_PROFILE=operator
# TOKOVO_LOG_LEVEL=info
# TOKOVO_LOG_COMPONENTS=app,engine,plugin,render-service,compiler
# TOKOVO_LOG_CONSOLE=true
# TOKOVO_LOG_COLORS=true
# TOKOVO_LOG_TIMESTAMPS=true
# TOKOVO_LOG_INCLUDE_STACKS=false
# TOKOVO_LOG_EVENTS=false
# TOKOVO_LOG_PERF=false
# TOKOVO_LOG_AUDIO=false
# Optional: override the NDJSON job log path instead of writing into the render artifact folder.
# TOKOVO_LOG_PATH=/absolute/path/to/logs.ndjson
