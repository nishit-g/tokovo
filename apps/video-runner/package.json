{
  "name": "video-runner",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "default": "./src/index.ts"
    },
    "./render-data": {
      "default": "./src/render-data.ts"
    },
    "./runtime": {
      "default": "./src/runtime.ts"
    },
    "./episode-registry": {
      "default": "./src/episode-registry.ts"
    }
  },
  "scripts": {
    "start": "npx remotion studio",
    "dev": "npx remotion studio",
    "dev:catalog": "TOKOVO_EPISODE_CATALOG_PROFILE=studio npx remotion studio",
    "benchmark": "npx remotion benchmark src/index.ts episode-render --props='{\"episodeId\":\"v2-enterprise-long-showcase\"}'",
    "render:fast": "sh scripts/render-fast.sh",
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "upgrade": "remotion upgrade",
    "pretest": "pnpm -w build:video",
    "test": "vitest run && pnpm run lint",
    "lint": "eslint src"
  },
  "dependencies": {
    "@remotion/bundler": "4.0.409",
    "@remotion/cli": "4.0.409",
    "@remotion/renderer": "4.0.409",
    "@tokovo/background": "workspace:*",
    "@tokovo/compiler": "workspace:*",
    "@tokovo/apps-instagram": "workspace:*",
    "@tokovo/apps-imessage": "workspace:*",
    "@tokovo/apps-linkedin": "workspace:*",
    "@tokovo/apps-snapchat": "workspace:*",
    "@tokovo/apps-teams": "workspace:*",
    "@tokovo/apps-typewriter": "workspace:*",
    "@tokovo/apps-whatsapp": "workspace:*",
    "@tokovo/apps-x": "workspace:*",
    "@tokovo/core": "workspace:*",
    "@tokovo/device-camera": "workspace:*",
    "@tokovo/device-keyboard": "workspace:*",
    "@tokovo/devices": "workspace:*",
    "@tokovo/device-notifications": "workspace:*",
    "@tokovo/dsl": "workspace:*",
    "@tokovo/overlay": "workspace:*",
    "@tokovo/episodes": "workspace:*",
    "@tokovo/ir": "workspace:*",
    "@tokovo/publishing": "workspace:*",
    "@tokovo/react": "workspace:*",
    "@tokovo/reactions": "workspace:*",
    "@tokovo/reactors": "workspace:*",
    "@tokovo/renderer": "workspace:*",
    "@tokovo/voice": "workspace:*",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "remotion": "4.0.409",
    "zod": "^4.2.1"
  },
  "devDependencies": {
    "@types/react": "18.3.1",
    "@types/web": "^0.0.61",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.20.6",
    "typescript": "^5.0.0",
    "vitest": "^1.0.0"
  }
}
